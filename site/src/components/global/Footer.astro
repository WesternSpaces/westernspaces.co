---
const year = new Date().getFullYear();
---

<footer class="bg-bark text-cream/80">
  <div class="max-w-6xl mx-auto px-6 py-8 md:py-12">
    <p class="text-sm font-serif font-semibold uppercase tracking-wider text-cream/60 leading-loose text-center mb-6 md:mb-8">
      Analyze the Past &middot; Understand Today &middot; Plan for Tomorrow
    </p>
    <div class="border-t border-cream/10 pt-6 text-center text-xs text-cream/60">
      <p>&copy; {year} Western Spaces. All rights reserved.</p>
      <p class="mt-1">All photographs by Sarah Brown McClain.</p>
    </div>
  </div>
</footer>
