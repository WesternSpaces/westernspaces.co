---
interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalURL?: string;
  type?: 'website' | 'article';
  publishedDate?: string;
}

const {
  title,
  description,
  image = '/og-default.jpg',
  canonicalURL = Astro.url.href,
  type = 'website',
  publishedDate,
} = Astro.props;

const siteTitle = 'Western Spaces';
const fullTitle = title === siteTitle ? title : `${title} | ${siteTitle}`;
const ogImage = new URL(image, Astro.site).href;
---

<!-- Primary -->
<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:alt" content="Western Spaces — Housing Research & Community Planning" />
<meta property="og:site_name" content={siteTitle} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

{publishedDate && <meta property="article:published_time" content={publishedDate} />}

<!-- JSON-LD -->
{type === 'article' ? (
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: fullTitle,
    description,
    url: canonicalURL,
    image: ogImage,
    ...(publishedDate && { datePublished: publishedDate }),
  })} />
) : (
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'ProfessionalService',
    name: 'Western Spaces',
    description: 'Housing research consultancy providing Colorado housing needs assessments, rural housing policy guidance, and market studies for Mountain West communities.',
    url: 'https://westernspaces.co',
    telephone: '+19702753154',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Salida',
      addressRegion: 'CO',
      addressCountry: 'US',
    },
    areaServed: 'Mountain West, United States',
    priceRange: '$$',
    image: ogImage,
    knowsAbout: [
      'Housing Needs Assessments',
      'Rural Housing Policy',
      'Market Feasibility Analysis',
      'Community Planning',
      'Housing Action Plans',
      'Colorado Proposition 123 Compliance',
    ],
  })} />
)}
