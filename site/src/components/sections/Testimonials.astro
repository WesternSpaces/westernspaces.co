---
/**
 * Testimonials component — ready to drop into index.astro when real quotes are available.
 *
 * Usage:
 *   import Testimonials from '../components/sections/Testimonials.astro';
 *   <Testimonials testimonials={[
 *     { quote: "...", name: "Jane Doe", title: "Executive Director", org: "Housing Authority" },
 *   ]} />
 */

interface Testimonial {
  quote: string;
  name: string;
  title?: string;
  org?: string;
}

interface Props {
  testimonials: Testimonial[];
}

const { testimonials } = Astro.props;
---

<section class="bg-cream py-10 md:py-20">
  <div class="max-w-6xl mx-auto px-6">
    <div class:list={[
      'grid gap-12',
      testimonials.length > 1 ? 'md:grid-cols-2' : 'max-w-3xl mx-auto',
    ]}>
      {testimonials.map((t) => (
        <blockquote class="border-l-4 border-gold pl-6">
          <p class="text-lg md:text-xl font-serif italic text-charcoal/90 leading-relaxed mb-4">
            "{t.quote}"
          </p>
          <footer class="text-sm text-ridge">
            <span class="font-semibold text-bark">{t.name}</span>
            {(t.title || t.org) && (
              <span>
                {t.title && `, ${t.title}`}
                {t.org && `, ${t.org}`}
              </span>
            )}
          </footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>
