---
import Button from '../ui/Button.astro';
---

<section class="bg-sandstone py-12 md:py-16">
  <div class="max-w-4xl mx-auto px-6 text-center">
    <h2 class="text-3xl md:text-4xl font-serif font-bold text-snow mb-4">
      Ready to start a project?
    </h2>
    <p class="text-lg text-snow/80 mb-8 max-w-xl mx-auto">
      Let's talk about what your community or project needs.
    </p>
    <Button href="/contact" size="lg" style="background-color: #FAF6F0; color: #3D2B1F;" class="hover:opacity-90">
      Get in Touch
    </Button>
  </div>
</section>
