---
import { Image } from 'astro:assets';
import Button from '../ui/Button.astro';
import heroImage from '../../assets/images/hero/foliage.jpg';
---

<section class="relative bg-bark overflow-hidden">
  <Image
    src={heroImage}
    alt=""
    class="absolute inset-0 w-full h-full object-cover opacity-40"
    widths={[800, 1200, 1920]}
    sizes="100vw"
    quality={70}
  />

  <div class="relative max-w-6xl mx-auto px-6 py-16 md:py-32 lg:py-40">
    <div class="max-w-3xl">
      <p class="text-sandstone text-base font-semibold uppercase tracking-[0.2em] mb-6">
        Housing Research &amp; Community Planning
      </p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-bold text-cream leading-[1.1] mb-6">
        The data behind better
        <span class="text-gold">housing policy</span>
      </h1>
      <p class="text-lg md:text-xl text-cream leading-relaxed mb-8 max-w-2xl">
        From statewide policy frameworks to small-town market studies — research that holds up and gets projects funded.
      </p>
      <div class="flex flex-wrap gap-4">
        <Button href="/projects" size="lg">View Projects</Button>
        <Button href="/contact" variant="outline" size="lg" class="bg-bark/30">Get in Touch</Button>
      </div>
    </div>
  </div>
</section>
