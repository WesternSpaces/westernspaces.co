---
import { Image } from 'astro:assets';
import Button from '../ui/Button.astro';
import aboutImage from '../../assets/images/about/skiing.jpg';
---

<section class="bg-cream py-12 md:py-16">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-16 items-center">
      <div>
        <span class="text-sm font-semibold uppercase tracking-[0.2em] text-sandstone mb-3 block">About</span>
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-bark mb-6">
          Research rooted in place
        </h2>
        <p class="text-charcoal/80 leading-relaxed mb-4">
          When housing costs outrun local wages, communities lose the people that hold them together. We work in places where that's already happening — and where the answers have to fit the place.
        </p>
        <p class="text-charcoal/80 leading-relaxed mb-4">
          Our clients are the local governments, housing authorities, nonprofits, and private developers doing the hard work of keeping communities housed — in Colorado and across the Mountain West.
        </p>
        <p class="text-charcoal/80 leading-relaxed mb-8">
          We combine demographic modeling, market analysis, and on-the-ground engagement to deliver research that holds up under scrutiny and moves projects forward.
        </p>
        <Button href="/about" variant="secondary">Learn More</Button>
      </div>
      <Image
        src={aboutImage}
        alt="Sarah Brown McClain in the Colorado backcountry"
        class="rounded-lg w-full object-cover aspect-[4/3]"
        widths={[400, 600, 800]}
        sizes="(min-width: 768px) 50vw, 100vw"
        quality={80}
      />
    </div>
  </div>
</section>
