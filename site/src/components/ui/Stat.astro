---
interface Props {
  value: string;
  label: string;
}

const { value, label } = Astro.props;
---

<div class="text-center">
  <div class="text-xl sm:text-3xl md:text-4xl font-serif font-bold text-gold">{value}</div>
  <div class="mt-1 text-xs sm:text-sm text-cream/70 uppercase tracking-wider">{label}</div>
</div>
