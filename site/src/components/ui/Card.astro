---
interface Props {
  href?: string;
  class?: string;
  [key: string]: any;
}

const { href, class: className = '', ...rest } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag
  href={href}
  class:list={[
    'block bg-snow rounded-lg shadow-sm border border-parchment overflow-hidden',
    'transition-all duration-200',
    href && 'hover:shadow-md hover:-translate-y-0.5',
    className,
  ]}
  {...rest}
>
  <slot />
</Tag>
