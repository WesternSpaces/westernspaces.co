---
interface Props {
  stats: { value: string; label: string }[];
}

const { stats } = Astro.props;
---

<div class="mt-10 bg-parchment/50 rounded-lg px-6 py-6 grid grid-cols-2 sm:grid-cols-3 gap-6 text-center">
  {stats.map((stat) => (
    <div>
      <div class="text-2xl md:text-3xl font-serif font-bold text-gold">{stat.value}</div>
      <div class="mt-1 text-xs text-ridge uppercase tracking-wider">{stat.label}</div>
    </div>
  ))}
</div>
