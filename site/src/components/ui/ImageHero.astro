---
import { Image } from 'astro:assets';

interface Props {
  title: string;
  subtitle?: string;
  image?: ImageMetadata;
  imagePosition?: string;
  class?: string;
}

const { title, subtitle, image, imagePosition, class: className = '' } = Astro.props;
---

<section class:list={['relative bg-bark py-24 md:py-32 overflow-hidden', className]}>
  {image && (
    <Image
      src={image}
      alt=""
      class="absolute inset-0 w-full h-full object-cover opacity-40"
      style={imagePosition ? `object-position: ${imagePosition}` : undefined}
      widths={[800, 1200, 1600]}
      sizes="100vw"
      quality={70}
    />
  )}
  <div class="relative max-w-6xl mx-auto px-6 text-center">
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-bold text-cream leading-tight">
      {title}
    </h1>
    {subtitle && (
      <p class="mt-4 text-lg md:text-xl text-cream max-w-2xl mx-auto">
        {subtitle}
      </p>
    )}
  </div>
</section>
