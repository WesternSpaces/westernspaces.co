---
import PageLayout from './PageLayout.astro';
import Tag from '../components/ui/Tag.astro';
import ProjectStats from '../components/ui/ProjectStats.astro';
import Button from '../components/ui/Button.astro';

interface Props {
  frontmatter: {
    title: string;
    client: string;
    year: number;
    location: string;
    category: string;
    summary: string;
    coverImage?: string;
    deliverables?: string[];
    externalUrl?: string;
    stats?: { value: string; label: string }[];
    year2?: number;
  };
  slug: string;
  allProjects: { id: string; title: string; category: string }[];
}

const { frontmatter, slug, allProjects } = Astro.props;
const categoryLabel = frontmatter.category.replace(/-/g, ' ');

const categoryOrder = [
  { value: 'policy-guidance', label: 'Policy & Technical Assistance' },
  { value: 'housing-needs-assessment', label: 'Housing Needs Assessments' },
  { value: 'housing-strategy', label: 'Housing Strategy' },
  { value: 'market-feasibility-analysis', label: 'Market & Feasibility' },
  { value: 'comprehensive-planning', label: 'Comprehensive Planning' },
];

const projectsByCategory = categoryOrder
  .map((cat) => ({
    label: cat.label,
    projects: allProjects.filter((p) => p.category === cat.value),
  }))
  .filter((group) => group.projects.length > 0);
---

<PageLayout title={frontmatter.title} description={frontmatter.summary}>
  <div class="max-w-7xl mx-auto px-6 py-16 lg:flex lg:gap-12">
    <!-- Main content -->
    <article class="max-w-3xl flex-1 min-w-0">
      <!-- Header -->
      <header class="mb-12">
        <div class="flex items-center gap-3 mb-4">
          <Tag>{categoryLabel}</Tag>
          <span class="text-sm text-ridge">{frontmatter.ongoing ? `${frontmatter.year}–present` : frontmatter.year2 ? `${frontmatter.year}–${frontmatter.year2}` : frontmatter.year}</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-serif font-bold text-bark leading-tight mb-4">
          {frontmatter.title}
        </h1>
        <p class="text-lg text-ridge">{frontmatter.summary}</p>

        <dl class="mt-8 grid grid-cols-2 sm:grid-cols-3 gap-6 text-sm border-t border-parchment pt-8">
          <div>
            <dt class="font-semibold text-bark uppercase tracking-wider text-sm mb-1">Client</dt>
            <dd class="text-charcoal">{frontmatter.client}</dd>
          </div>
          <div>
            <dt class="font-semibold text-bark uppercase tracking-wider text-sm mb-1">Location</dt>
            <dd class="text-charcoal">{frontmatter.location}</dd>
          </div>
          {frontmatter.deliverables && (
            <div>
              <dt class="font-semibold text-bark uppercase tracking-wider text-sm mb-1">Deliverables</dt>
              <dd class="text-charcoal">{frontmatter.deliverables.join(', ')}</dd>
            </div>
          )}
        </dl>

        {frontmatter.stats && <ProjectStats stats={frontmatter.stats} />}
      </header>

      <!-- Content -->
      <div class="prose prose-lg max-w-none">
        <slot />
      </div>

      {frontmatter.externalUrl && (
        <div class="mt-12 flex justify-center">
          <Button href={frontmatter.externalUrl} variant="outline" size="md" target="_blank" rel="noopener noreferrer">
            View project &rarr;
          </Button>
        </div>
      )}

      <!-- Back link -->
      <div class="mt-8 pt-8 border-t border-parchment">
        <a href="/projects" class="text-gold font-semibold hover:underline">&larr; All Projects</a>
      </div>
    </article>

    <!-- Sidebar nav -->
    <nav class="hidden lg:block w-56 shrink-0" aria-label="Project navigation">
      <div class="sticky top-8 max-h-[calc(100vh-4rem)] overflow-y-auto">
        {projectsByCategory.map((group) => (
          <div class="mb-4">
            <h3 class="text-xs font-semibold text-bark uppercase tracking-wider mb-1 px-2">{group.label}</h3>
            <ul class="space-y-0.5 text-sm">
              {group.projects.map((p) => (
                <li>
                  <a
                    href={`/projects/${p.id}`}
                    class:list={[
                      'block px-2 py-1 rounded transition-colors leading-snug',
                      p.id === slug
                        ? 'text-gold font-semibold bg-parchment/60'
                        : 'text-ridge hover:text-bark hover:bg-parchment/40',
                    ]}
                    aria-current={p.id === slug ? 'page' : undefined}
                  >
                    {p.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </nav>
  </div>
</PageLayout>
